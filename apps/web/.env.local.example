# Praetor frontend dev configuration
# Copy to .env.local and adjust.

# API gateway base URL. The frontend uses a stubbed in-memory client by default
# (see lib/api/index.ts). Set this only if you wire the real FastAPI backend.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Dev bearer used by the API client. Matches the FastAPI dev middleware.
NEXT_PUBLIC_DEV_BEARER=dev

# When set to "1", the UI will simulate live event streams via setInterval
# rather than opening WebSockets. Default behaviour for hackathon scope.
NEXT_PUBLIC_MOCK_STREAMS=1
